assert 0x1234 == 4660;
assert 0o1234 == 668;
assert 0b10101110 == 174;
assert 0x00ff_ffff == 16777215;

assert 123e3 == 123000.0;
assert 123e-3 == 0.123;
assert 1.23e-3 == 0.00123;
assert 0.0123e3 == 12.3;
assert 0.0123e-3 == 0.0000123;

assert 123e4 == 1230000.0;
assert 123e-4 == 0.0123;
assert 1.23e-4 == 0.000123;
assert 0.0123e4 == 123.0;
assert 0.0123e-4 == 0.00000123;

assert 123e5 == 12300000.0;
assert 123e-5 == 0.00123;
assert 1.23e-5 == 0.0000123;
assert 0.0123e5 == 1230.0;
assert 0.0123e-5 == 0.000000123;

assert 123e6 == 123000000.0;
assert 123e-6 == 0.000123;
assert 1.23e-6 == 0.00000123;
assert 0.0123e6 == 12300.0;
assert 0.0123e-6 == 0.0000000123;

assert 123e7 == 1230000000.0;
assert 123e-7 == 0.0000123;
assert 1.23e-7 == 0.000000123;
assert 0.0123e7 == 123000.0;
assert 0.0123e-7 == 0.00000000123;

assert #x33 == #51;
assert #65 == b'A';

assert 0x123456789abcdef123456789abcdef99999 == 99114423104580546086788483819363542604185;

assert -2 < -1 && 0 < 2;
