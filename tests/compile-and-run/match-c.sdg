fn isqrt(n: Int) -> Int = match n {
    ..0 => std.panic(),
    0..1 => 0,
    1..4 => 1,
    4..9 => 2,
    9..16 => 3,
    16..25 => 4,
    25..36 => 5,
    36..49 => 6,
    49..64 => 7,
    64..81 => 8,
    81..100 => 9,
    100..121 => 10,
    121..144 => 11,
    144..169 => 12,
    169..196 => 13,
    196..225 => 14,
    225..256 => 15,
    256..289 => 16,
    289..324 => 17,
    324..361 => 18,
    361..400 => 19,
    _ => {
        let ssqrt = isqrt(n / 16) * 4;

        match () {
            _ if ssqrt * ssqrt <= n => ssqrt,
            _ if (ssqrt + 1) * (ssqrt + 1) <= n => ssqrt + 1,
            _ if (ssqrt + 2) * (ssqrt + 2) <= n => ssqrt + 2,
            _ => ssqrt + 3,
        }
    },
};

assert isqrt(10) == 3;
assert isqrt(100) == 10;
assert isqrt(1000) == 31;
assert isqrt(10000) == 100;
assert isqrt(100000) == 316;

assert isqrt(200_000_000_000_000_000_000_000_000) == 14142135623730;
assert isqrt(300_000_000_000_000_000_000_000_000) == 17320508075688;
assert isqrt(1_000_000_000_000_000_000_000_000_000) == 31622776601683;
