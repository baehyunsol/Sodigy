fn stupid_parser(s: String) -> Int = match s {
    "zero" => 0,
    "one" => 1,
    "two" => 2,
    "three" => 3,
    "four" => 4,
    "five" => 5,
    "six" => 6,
    "seven" => 7,
    "eight" => 8,
    "nine" => 9,
    "ten" => 10,
    "eleven" => 11,
    "twelve" => 12,
    "thirteen" => 13,
    "fourteen" => 14,
    "fifteen" => 15,
    "sixteen" => 16,
    "seventeen" => 17,
    "eighteen" => 18,
    "nineteen" => 19,
    "twenty" => 20,
    "thirty" => 30,
    "forty" => 40,
    $s ++ " one" => stupid_parser(s) + 1,
    $s ++ " two" => stupid_parser(s) + 2,
    $s ++ " three" => stupid_parser(s) + 3,
    $s ++ " four" => stupid_parser(s) + 4,
    $s ++ " five" => stupid_parser(s) + 5,
    $s ++ " six" => stupid_parser(s) + 6,
    $s ++ " seven" => stupid_parser(s) + 7,
    $s ++ " eight" => stupid_parser(s) + 8,
    $s ++ " nine" => stupid_parser(s) + 9,
    _ => -1,
};

assert stupid_parser("zero") == 0;
assert stupid_parser("one") == 1;
assert stupid_parser("two") == 2;
assert stupid_parser("three") == 3;
assert stupid_parser("four") == 4;
assert stupid_parser("twelve") == 12;
assert stupid_parser("twenty one") == 21;
assert stupid_parser("thirty five") == 35;
assert stupid_parser("forty two") == 42;
assert stupid_parser("forty three") == 43;
assert stupid_parser("None") == -1;

assert stupid_parser(" one") == 0;
assert stupid_parser("one two three") == 6;
assert stupid_parser("one one one") == 3;
assert stupid_parser(" one one one") == 2;
