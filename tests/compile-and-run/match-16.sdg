type Quaternary = Option<Option<Option<Int>>>;

fn foo(x: (Quaternary, Quaternary, Quaternary)) -> Int = match x {
    (None, None, None) => 0,
    (None, None, Some(None)) => 0,
    (None, None, Some(Some(None))) => 0,
    (None, None, Some(Some(Some($x)))) => x,
    (None, Some(None), None) => 0,
    (None, Some(None), Some(None)) => 0,
    (None, Some(None), Some(Some(None))) => 0,
    (None, Some(None), Some(Some(Some($x)))) => x,
    (None, Some(Some(None)), None) => 0,
    (None, Some(Some(None)), Some(None)) => 0,
    (None, Some(Some(None)), Some(Some(None))) => 0,
    (None, Some(Some(None)), Some(Some(Some($x)))) => x,
    (None, Some(Some(Some($x))), None) => x,
    (None, Some(Some(Some($x))), Some(None)) => x,
    (None, Some(Some(Some($x))), Some(Some(None))) => x,
    (None, Some(Some(Some(_))), Some(Some(Some($x)))) => x,
    (Some(None), None, None) => 0,
    (Some(None), None, Some(None)) => 0,
    (Some(None), None, Some(Some(None))) => 0,
    (Some(None), None, Some(Some(Some($x)))) => x,
    (Some(None), Some(None), None) => 0,
    (Some(None), Some(None), Some(None)) => 0,
    (Some(None), Some(None), Some(Some(None))) => 0,
    (Some(None), Some(None), Some(Some(Some($x)))) => x,
    (Some(None), Some(Some(None)), None) => 0,
    (Some(None), Some(Some(None)), Some(None)) => 0,
    (Some(None), Some(Some(None)), Some(Some(None))) => 0,
    (Some(None), Some(Some(None)), Some(Some(Some($x)))) => x,
    (Some(None), Some(Some(Some($x))), None) => x,
    (Some(None), Some(Some(Some($x))), Some(None)) => x,
    (Some(None), Some(Some(Some($x))), Some(Some(None))) => x,
    (Some(None), Some(Some(Some(_))), Some(Some(Some($x)))) => x,
    (Some(Some(None)), None, None) => 0,
    (Some(Some(None)), None, Some(None)) => 0,
    (Some(Some(None)), None, Some(Some(None))) => 0,
    (Some(Some(None)), None, Some(Some(Some($x)))) => x,
    (Some(Some(None)), Some(None), None) => 0,
    (Some(Some(None)), Some(None), Some(None)) => 0,
    (Some(Some(None)), Some(None), Some(Some(None))) => 0,
    (Some(Some(None)), Some(None), Some(Some(Some($x)))) => x,
    (Some(Some(None)), Some(Some(None)), None) => 0,
    (Some(Some(None)), Some(Some(None)), Some(None)) => 0,
    (Some(Some(None)), Some(Some(None)), Some(Some(None))) => 0,
    (Some(Some(None)), Some(Some(None)), Some(Some(Some($x)))) => x,
    (Some(Some(None)), Some(Some(Some($x))), None) => x,
    (Some(Some(None)), Some(Some(Some($x))), Some(None)) => x,
    (Some(Some(None)), Some(Some(Some($x))), Some(Some(None))) => x,
    (Some(Some(None)), Some(Some(Some(_))), Some(Some(Some($x)))) => x,
    (Some(Some(Some($x))), None, None) => x,
    (Some(Some(Some($x))), None, Some(None)) => x,
    (Some(Some(Some($x))), None, Some(Some(None))) => x,
    (Some(Some(Some(_))), None, Some(Some(Some($x)))) => x,
    (Some(Some(Some($x))), Some(None), None) => x,
    (Some(Some(Some($x))), Some(None), Some(None)) => x,
    (Some(Some(Some($x))), Some(None), Some(Some(None))) => x,
    (Some(Some(Some(_))), Some(None), Some(Some(Some($x)))) => x,
    (Some(Some(Some($x))), Some(Some(None)), None) => x,
    (Some(Some(Some($x))), Some(Some(None)), Some(None)) => x,
    (Some(Some(Some($x))), Some(Some(None)), Some(Some(None))) => x,
    (Some(Some(Some(_))), Some(Some(None)), Some(Some(Some($x)))) => x,
    (Some(Some(Some(_))), Some(Some(Some($x))), None) => x,
    (Some(Some(Some(_))), Some(Some(Some($x))), Some(None)) => x,
    (Some(Some(Some(_))), Some(Some(Some($x))), Some(Some(None))) => x,
    (Some(Some(Some(_))), Some(Some(Some(_))), Some(Some(Some($x)))) => x,
};

fn destruct(n: Int) -> (Quaternary, Quaternary, Quaternary) = {
    let vs = [
        \(_) => None,
        \(_) => Some(None),
        \(_) => Some(Some(None)),
        \(i) => Some(Some(Some(i))),
    ];

    (
        vs[n / 16](10),
        vs[n / 4 % 4](20),
        vs[n % 4](30),
    )
};

assert foo(destruct(0)) == 0;
assert foo(destruct(1)) == 0;
assert foo(destruct(2)) == 0;
assert foo(destruct(3)) == 30;
