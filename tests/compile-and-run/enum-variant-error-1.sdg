enum Foo = {
    V1,
    V2(Int),
    V3 { x1: Int, x2: String },
};

// let x10 = Foo.V1;  // not error
// let x11 = Foo.V1();  // not caught by mir
// let x12 = Foo.V1(3);  // not caught by mir
let x13 = Foo.V1 { x1: 3 };  // error
let x14 = Foo.V1 { x1: 3, x2: "" };  // error

// let x20 = Foo.V2;  // not caught by mir
// let x21 = Foo.V2();  // not caught by mir
// let x22 = Foo.V2(3);  // not error
let x23 = Foo.V2 { x1: 3 };  // error
let x24 = Foo.V2 { x1: 3, x2: "" };  // error

// let x30 = Foo.V3;  // not caught by mir
// let x31 = Foo.V3();  // not caught by mir
// let x32 = Foo.V3(3);  // not caught by mir
let x33 = Foo.V3 { x1: 3 };  // error
