enum Animal = {
    Human { name: String, age: Int },
    Dog(String),
    Cat,
};

fn get_name(animal) = match animal {
    Animal.Human { name: $name, .. } => Some(name),
    Animal.Dog($name) => Some(name),
    Animal.Cat => None,
};

assert get_name(Animal.Human { name: "Bae", age: 28 }).unwrap() == "Bae";
assert get_name(Animal.Dog("Kim")).unwrap() == "Kim";
assert get_name(Animal.Cat) == None;
