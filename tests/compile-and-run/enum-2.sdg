pub enum MyOption<T> = {
    Some { id: Int, value: T },
    None,
};

assert MyOption.Some { id: 0, value: "abc" } == MyOption.Some { id: 0, value: "abc" };
assert MyOption.Some { id: 0, value: "abc" } != MyOption.None;
assert MyOption.Some { id: 0, value: "abc" } != MyOption.Some { id: 0, value: "abcd" };
