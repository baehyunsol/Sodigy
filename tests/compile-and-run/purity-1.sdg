fn pure_func(n: Int) -> Int = n + 1;

proc impure_func(n: Int) -> Int = std.random.random_int() + n;

let f1: Callable(Int) -> Int = pure_func;
let f2: Fn(Int) -> Int = pure_func;
// let f3: Proc(Int) -> Int = pure_func;  // type error

let f4: Callable(Int) -> Int = impure_func;
// let f5: Fn(Int) -> Int = impure_func;  // type error
let f6: Proc(Int) -> Int = impure_func;

let funcs1: [Callable(Int) -> Int] = [pure_func, impure_func];
let funcs2: [Callable(Int) -> Int] = [pure_func, pure_func];
let funcs3: [Callable(Int) -> Int] = [impure_func, impure_func];

// let funcs4: [Fn(Int) -> Int] = [pure_func, impure_func];  // type error
let funcs5: [Fn(Int) -> Int] = [pure_func, pure_func];
// let funcs6: [Fn(Int) -> Int] = [impure_func, impure_func];  // type error

// let funcs7: [Proc(Int) -> Int] = [pure_func, impure_func];  // type error
// let funcs8: [Proc(Int) -> Int] = [pure_func, pure_func];  // type error
let funcs9: [Proc(Int) -> Int] = [impure_func, impure_func];

let lambda1: Callable(Int) -> Int = \(n) => n + 1;
let lambda2: Fn(Int) -> Int = \(n) => n + 1;
// let lambda3: Proc(Int) -> Int = \(n) => n + 1;  // type error

let lambda4: Callable(Int) -> Int = impure \(n) => std.random.random_int() + n;
// let lambda5: Fn(Int) -> Int = impure \(n) => std.random.random_int() + n;  // type error
let lambda6: Proc(Int) -> Int = impure \(n) => std.random.random_int() + n;
