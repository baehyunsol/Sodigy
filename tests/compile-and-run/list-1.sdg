// TODO: move this to std, and add tests

#[associate([T])]
fn map<T, U>(self, f: PureFn(T) -> U) -> [U] = match self {
    [] => [],
    [$x] ++ $rem => [f(x)] ++ rem.map(f),
};

#[associate([T])]
fn filter<T>(self, f: Fn(T) -> Bool) -> [T] = match self {
    [] => [],
    [$x] ++ $rem => if f(x) { [x] ++ rem.filter(f) } else { rem.filter(f) },
};

#[associate([T])]
fn sort<T>(self) -> [T] = match self {
    [] | [_] => self,
    _ => self.filter(\(x) => x < self[0]).sort() ++ self.filter(\(x) => x == self[0]) ++ self.filter(\(x) => x > self[0]).sort(),
};

#[associate([T])]
fn reverse<T>(self) -> [T] = match self {
    [] | [_] => self,
    [$x] ++ $rem => rem.reverse() ++ [x],
};

#[associate([T])]
fn length<T>(self) -> Int = match self {
    [] => 0,
    [_] ++ $rem => 1 + rem.length(),
};

#[associate([T])]
fn find<T>(self, f: PureFn(T) -> Bool) -> Option<T> = match self {
    [] => None,
    [$x] ++ $xs => if f(x) { Some(x) } else { xs.find(f) },
};
